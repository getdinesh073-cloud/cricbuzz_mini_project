# Streamlit Configuration
DEBUG=False                            # Enable debug mode
LOG_LEVEL=INFO                         # Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_FILE=cricbuzz_app.log              # Log file path

# Application Settings
