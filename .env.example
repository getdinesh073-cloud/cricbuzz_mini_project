# Database Configuration
DB_TYPE=sqlite                          # Options: sqlite, postgresql, mysql
DB_NAME=cricbuzz.db                    # Database name/path
DB_HOST=localhost                      # Database host
DB_PORT=5432                           # Database port
DB_USER=                               # Database user (not needed for SQLite)
DB_PASSWORD=                           # Database password (not needed for SQLite)
DB_TIMEOUT=30                          # Connection timeout in seconds

# API Configuration
CRICBUZZ_API_BASE_URL=https://api.cricbuzz.com/v1
CRICBUZZ_API_KEY=                      # Add your API key here
API_TIMEOUT=10                         # Request timeout in seconds
API_RETRY_COUNT=3                      # Number of retries for failed requests

# Streamlit Configuration
DEBUG=False                            # Enable debug mode
LOG_LEVEL=INFO                         # Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_FILE=cricbuzz_app.log              # Log file path

# Application Settings
BATCH_SIZE=100                         # Batch size for data operations
QUERY_TIMEOUT=30                       # SQL query timeout
MAX_ROWS_DISPLAY=1000                  # Maximum rows to display
CACHE_DURATION=300                     # Cache duration in seconds
