# Database Configuration
# Options: sqlite, postgresql, mysql
# For XAMPP MySQL: DB_TYPE=mysql, DB_HOST=localhost, DB_PORT=3306, DB_USER=root, DB_PASSWORD=(empty)
DB_TYPE=sqlite                          # Options: sqlite, postgresql, mysql
DB_NAME=cricbuzz.db                    # Database name/path (or DB name for MySQL/PostgreSQL)
DB_HOST=localhost                      # Database host
DB_PORT=3306                           # Database port (3306 for MySQL, 5432 for PostgreSQL)
DB_USER=root                           # Database user (required for MySQL/PostgreSQL)
DB_PASSWORD=                           # Database password (required for MySQL/PostgreSQL)
DB_TIMEOUT=30                          # Connection timeout in seconds

# API Configuration (RapidAPI - Cricbuzz Cricket)
# Get API key from: https://rapidapi.com/api-sports/api/cricbuzz-cricket
RAPIDAPI_KEY=954838e7f1msh87d1b6fbce80151p1660d7jsne8d15ff691d7
RAPIDAPI_HOST=cricbuzz-cricket.p.rapidapi.com
API_TIMEOUT=10                         # Request timeout in seconds
API_RETRY_COUNT=3                      # Number of retries for failed requests

# Streamlit Configuration
DEBUG=False                            # Enable debug mode
LOG_LEVEL=INFO                         # Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_FILE=cricbuzz_app.log              # Log file path

# Application Settings
BATCH_SIZE=100                         # Batch size for data operations
QUERY_TIMEOUT=30                       # SQL query timeout
MAX_ROWS_DISPLAY=1000                  # Maximum rows to display
CACHE_DURATION=300                     # Cache duration in seconds
